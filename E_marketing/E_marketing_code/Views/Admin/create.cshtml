@model emarketing.Models.tbl_category

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Add Category";
}

@section Styles {
    <style>
        .category-container {
            background-color: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            width: 300px;
            margin: 20px auto;
        }

        h2 {
            text-align: center;
            color: #333;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 15px;
            position: relative;
        }

            .form-group label {
                display: block;
                margin-bottom: 5px;
                color: #666;
            }

            .form-group input {
                width: 85%;
                padding: 10px 10px 10px 30px;
                border: 1px solid #ccc;
                border-radius: 4px;
                max-width: 85%;
            }

            .form-group .icon {
                position: absolute;
                left: 10px;
                top: 35px;
                color: #666;
            }

        .btn {
            width: 100%;
            padding: 10px;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 16px;
            margin-bottom: 10px;
        }

            .btn:hover {
                background-color: #45a049;
            }
    </style>
}

<div class="category-container">
    <h2>Add Category</h2>
    @using (Html.BeginForm("create", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        <div class="form-group">
            <label for="cat_name">Category Name</label>
            <i class="fas fa-tag icon"></i>
            @Html.TextBoxFor(m => m.cat_name, new { @class = "form-control", @id = "cat_name", @required = "required" })
        </div>
        <div class="form-group">
            <label for="cat_image">Category Image</label>
            <i class="fas fa-image icon"></i>
            @Html.TextBoxFor(m => m.cat_image, new { @type = "file", @class = "form-control", @id = "cat_image", @required = "required" })
        </div>
        <button type="submit" class="btn">Add Category</button>
        <div class="form-group">
            <p style="color: red;">@ViewBag.error</p>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/jqueryval")
}
