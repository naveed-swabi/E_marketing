@model PagedList.IPagedList<emarketing.Models.tbl_category>

@using PagedList.Mvc;

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "View Categories";
    string logoPath = Url.Content("~/Content/ImageUpload/e-commerc.png"); // Update with your actual logo path
}

<div class="container-with-sidebar">
    <div class="main-content">
        <div class="text-center">
            <img src="@logoPath" alt="Website Logo" style="width: 150px; margin-bottom: 20px;" /> <!-- Logo -->
        </div>

        <h2 class="text-center">View Categories</h2>

        <div class="row">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="col-md-4 col-sm-6 col-xs-12 text-center">
                        <div class="card mb-3">
                            <div class="card-img-container">
                                <!-- START: Code to Allow Image Size Increase -->
                                <a href="@Url.Action("Ad", "User", new { id = item.cat_id })" class="img-anchor">
                                    <img src="@Url.Content(item.cat_image)" alt="@item.cat_name" class="card-img-top" />
                                </a>
                                <!-- END: Code to Allow Image Size Increase -->
                                <div class="card-body">
                                    <h5 class="card-title">
                                        <a href="@Url.Action("Ad", "User", new { id = item.cat_id })">
                                            @item.cat_name
                                        </a>
                                    </h5>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p>No Products found.</p>
            }
        </div>

        <div class="text-center">
            @if (Model != null && Model.Any())
            {
                @Html.PagedListPager(Model, page => Url.Action("Usercategory", new { page }), new PagedListRenderOptions
                {
                    DisplayLinkToFirstPage = PagedListDisplayMode.IfNeeded,
                    DisplayLinkToLastPage = PagedListDisplayMode.IfNeeded,
                    DisplayLinkToPreviousPage = PagedListDisplayMode.IfNeeded,
                    DisplayLinkToNextPage = PagedListDisplayMode.IfNeeded,
                    DisplayLinkToIndividualPages = true
                })
            }
            else
            {
                <p>No Products found.</p>
            }
        </div>
    </div>
</div>

<!-- Additional Styles for the Categories View -->
<style>
    .container-with-sidebar {
        display: flex;
        justify-content: space-between;
    }

    .main-content {
        flex: 1;
        padding-right: 20px; /* Space between main content and sidebar */
    }

    .card {
        box-shadow: none;
        border: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0;
        margin: 0;
        background: none;
        width: 100%;
        margin-bottom: 20px; /* Reduced space between cards */
    }

    .card-img-container {
        display: flex;
        flex-direction: column; /* Stack the image and name vertically */
        justify-content: center;
        align-items: center;
        padding: 0;
        width: 100%; /* Ensure container width is 100% */
        max-width: 300px; /* Set desired max width for the container */
        height: 300px; /* Set a fixed height to control image size */
        margin-bottom: 10px; /* Reduced space between image and title */
        overflow: hidden; /* Hide overflow to maintain fixed height */
    }

    .img-anchor {
        display: block; /* Makes the anchor tag take up the full width of the parent */
        width: 100%;
        height: 100%;
        text-align: center; /* Centers the image within the anchor tag */
    }

    .card-img-top {
        width: 100%; /* Ensure the image takes up 100% of the parent width */
        height: 100%; /* Ensure the image takes up 100% of the parent height */
        object-fit: cover; /* Scale image to fill the box while maintaining aspect ratio */
    }

    .card-body {
        text-align: center;
        width: 100%;
    }
</style>
